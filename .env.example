# Catalyst LLM Configuration
# Copy to .env for local development

# Ports (localhost only)
OLLAMA_PORT=11434
WEBUI_PORT=3030

# Default model to suggest in UI
DEFAULT_MODEL=dolphin-mistral:7b

# Resource limits (uncomment to set)
# OLLAMA_MAX_MEMORY=16g

# LiteLLM Configuration
LITELLM_MASTER_KEY=sk-change-me-in-production

# Cloud Providers (optional - leave empty for Ollama-only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
